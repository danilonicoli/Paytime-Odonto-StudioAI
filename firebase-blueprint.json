{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access control.",
      "type": "object",
      "properties": {
        "full_name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["admin", "manager", "receptionist", "dentist"], "description": "Access role" }
      },
      "required": ["full_name", "email", "role"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient record containing personal and clinical metadata.",
      "type": "object",
      "properties": {
        "full_name": { "type": "string", "description": "Full name of the patient" },
        "cpf": { "type": "string", "description": "CPF number" },
        "birth_date": { "type": "string", "format": "date", "description": "Date of birth" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Patient status" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Labels for categorization" }
      },
      "required": ["full_name", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled dental appointment.",
      "type": "object",
      "properties": {
        "patient_id": { "type": "string", "description": "ID of the patient" },
        "professional_id": { "type": "string", "description": "ID of the dentist" },
        "procedure": { "type": "string", "description": "Procedure name" },
        "start_at": { "type": "string", "format": "date-time", "description": "Start time" },
        "end_at": { "type": "string", "format": "date-time", "description": "End time" },
        "status": { "type": "string", "enum": ["scheduled", "confirmed", "checked_in", "completed", "cancelled"], "description": "Appointment status" }
      },
      "required": ["patient_id", "professional_id", "start_at", "status"]
    },
    "Charge": {
      "title": "Charge",
      "description": "Financial charge for a treatment or appointment.",
      "type": "object",
      "properties": {
        "patient_id": { "type": "string", "description": "ID of the patient" },
        "amount": { "type": "number", "description": "Total amount in BRL" },
        "status": { "type": "string", "enum": ["open", "paid", "cancelled"], "description": "Payment status" },
        "due_date": { "type": "string", "format": "date", "description": "Due date" }
      },
      "required": ["patient_id", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Collection of patient records"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of dental appointments"
    },
    "/charges/{chargeId}": {
      "schema": "Charge",
      "description": "Collection of financial charges"
    }
  }
}
